# Existing OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Existing Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=2000
ANTHROPIC_TEMPERATURE=0.7

# CrewAI Configuration
CREWAI_ENABLED=false
CREWAI_DEFAULT_LLM_PROVIDER=openai
CREWAI_AGENT_VERBOSE=true
CREWAI_TASK_VERBOSE=true
CREWAI_CREW_VERBOSE=true
CREWAI_MAX_EXECUTION_TIME=300
CREWAI_MAX_RETRY_ATTEMPTS=3

# CrewAI Agent Configuration
CREWAI_RESEARCHER_ROLE=Senior Research Analyst
CREWAI_RESEARCHER_GOAL=Uncover cutting-edge developments in AI and data science
CREWAI_WRITER_ROLE=Tech Content Strategist
CREWAI_WRITER_GOAL=Craft compelling content on tech advancements

# Default Provider (openai, anthropic, crewai)
DEFAULT_PROVIDER=openai