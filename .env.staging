# Application
NODE_ENV=staging
WEB_PORT=3000
LOG_LEVEL=info
API_KEY=staging-api-key-12345

# Database
DATABASE_URL=postgresql://staginguser:stagingpass@db:5432/stagingdb
DB_NAME=stagingdb
DB_USER=staginguser
DB_PASSWORD=stagingpass
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Monitoring
GRAFANA_PASSWORD=staging-grafana-pass