# Application
NODE_ENV=staging
WEB_PORT=3000
LOG_LEVEL=info
API_KEY=staging-api-key-12345

# Database
DATABASE_URL=postgresql://staginguser:stagingpass@postgres:5432/stagingdb
POSTGRES_DB=stagingdb
POSTGRES_USER=staginguser
POSTGRES_PASSWORD=stagingpass
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Monitoring
GRAFANA_PASSWORD=staging-grafana-pass